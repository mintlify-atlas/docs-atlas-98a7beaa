  "keyFeatures": [
    "Object-oriented OpenStack resource management",
    "Lazy-loading properties for efficient API usage",
    "Relationship traversal between resources (user->projects->servers)",
    "Custom EntityList with filter, sort, and map operations",
    "Multi-cloud support with configurable cloud credentials",
    "Comprehensive resource coverage (users, projects, servers, hypervisors, flavors, images, IPs, quotas)"
  ],
  "publicApiSurface": [
    "Cloud(cloud='admin')",
    "User(user_id=None, name=None, domain_name=None, cloud=Cloud())",
    "Project(project_id=None, name=None, cloud=Cloud())",
    "Server(server_id=None, name=None, cloud=Cloud())",
    "Hypervisor(hypervisor_id=None, name=None, cloud=Cloud())",
    "Domain(domain_id=None, name=None, cloud=Cloud())",
    "Flavor(flavor_id=None, name=None, cloud=Cloud())",
    "Image(image_id=None, name=None, cloud=Cloud())",
    "FloatingIP(fip_id=None, name=None, cloud=Cloud())",
    "Quota(data)",
    "EntityList.filter(filter_lambda)",
    "EntityList.sort(sort_lambda)",
    "EntityList.map(map_lambda)"
  ]
}
